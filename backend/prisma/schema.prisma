
generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

enum ApplicantStatus {
  PENDING
  SHORTLISTED
  ACCEPTED
  REJECTED
}

enum InternshipTrack {
  FRONTEND_DEVELOPMENT
  BACKEND_DEVELOPMENT
  MOBILE_DEVELOPMENT
  UI_UX_DESIGN
  DATA_ANALYTICS
}

model Admin {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  password  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Applicant {
  id        Int              @id @default(autoincrement())
  name      String
  email     String           @unique
  phone     String?
  track     InternshipTrack
  status    ApplicantStatus  @default(PENDING)
  notes     String?
  deletedAt DateTime?
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt
}